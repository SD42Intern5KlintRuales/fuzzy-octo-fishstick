        },
        {
          "sheet": "ReleaseNote",
          "fieldName": "Changes",
          "cell": "B14",
          "validationType": "REQUIRED",
          "failMessage": "Missing required input for Changes"
        },
        {
          "sheet": "ReleaseNote",
          "fieldName": "Supported Languages",
          "cell": "B16",
          "validationType": "REQUIRED",
          "failMessage": "Missing required input for Supported Languages"
        },
        {
          "sheet": "ReleaseNote",
          "fieldName": "Supported Machine(s)/Environment(s)",
          "cell": "B18",
          "validationType": "REQUIRED",
          "failMessage": "Missing required input for Supported Machine(s)/Environment(s)"
