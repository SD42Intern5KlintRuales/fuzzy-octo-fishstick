{
  "configVersion": "1.0",
  "lastUpdated": "2026-07-13",
  "settings": {
    "trimWhitespace": true,
    "treatWhitespaceOnlyAsBlank": true,
    "acceptPlaceholderValuesAsValid": true,
    "placeholderExamples": ["N/A", "-", "None"],
    "notes": "Placeholder values like N/A or - are treated as valid, non-blank input. The tool never tries to guess intent beyond blank vs not-blank."
  },
  "validationTypes": {
    "REQUIRED": "Cell must contain a non-blank value after trimming whitespace.",
    "REQUIRED_DATE": "Cell must contain a non-blank value after trimming, and that value must parse as a valid date."
  },
  "files": [
    {
