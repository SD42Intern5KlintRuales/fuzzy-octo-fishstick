        {
          "sheet": "ReleaseNote",
          "fieldName": "Limitations",
          "cell": "B20",
          "validationType": "REQUIRED",
          "failMessage": "Missing required input for Limitations"
        },
        {
          "sheet": "ReleaseDetailsHistory",
          "fieldName": "Release Date",
          "cell": "C3",
          "validationType": "REQUIRED_DATE",
          "failMessage": "Missing or invalid date for Release Date"
        },
        {
          "sheet": "ReleaseDetailsHistory",
          "fieldName": "Version",
          "cell": "C4",
          "validationType": "REQUIRED",
          "failMessage": "Missing required input for Version"
        },
        {
          "sheet": "ReleaseDetailsHistory",
          "fieldName": "Implemented function(s)/Fixed defect(s)",
          "cell": "C5",
          "validationType": "REQUIRED",
          "failMessage": "Missing required input for Implemented function(s)/Fixed defect(s)",
          "note": "If content spans multiple rows (C5:C6), this checks only the first configured cell. See optional enhancement in requirements doc."
        },
        {
          "sheet": "ReleaseDetailsHistory",
          "fieldName": "Known defect(s)/limitation(s)",
          "cell": "C7",
          "validationType": "REQUIRED",
          "failMessage": "Missing required input for Known defect(s)/limitation(s)"
        },
        {
          "sheet": "ReleaseDetailsHistory",
          "fieldName": "Note(s)",
          "cell": "C8",
          "validationType": "REQUIRED",
          "failMessage": "Missing required input for Note(s)"
        }
      ],
      "tableRules": [
        {
          "sheet": "Product_ReleaseCheckpoints",
          "tableName": "Release Checkpoints",
          "startRow": 4,
          "endCondition": {
                "type": "ALL_FIELDS_BLANK",
                "fields": [
                    "Category",
                    "Checkpoint",
                    "Result"
                ]
            },
          "columns": [
            {
              "fieldName": "Category",
              "column": "B",
              "required": false,
              "remarks": "Required only for the first row of a category group. Blank category is allowed on subsequent rows within the same group."
            },
            {
              "fieldName": "Checkpoint",
              "column": "C",
              "required": true,
              "failMessage": "Missing Checkpoint description"
            },
            {
              "fieldName": "Result",
              "column": "D",
              "required": true,
              "failMessage": "Missing Result for this checkpoint"
            }
          ],
          "rowValidationRules": [
                {
                    "type": "DEPENDENCY",
                    "ifField": "Checkpoint",
                    "requiredField": "Result",
                    "message": "Result is required when Checkpoint is provided"
                },
                {
                    "type": "DEPENDENCY",
                    "ifField": "Result",
                    "requiredField": "Checkpoint",
                    "message": "Checkpoint is required when Result is provided"
                },
                {
                    "type": "GROUP_HEADER_REQUIRED",
                    "field": "Category",
                    "dataFields": [
                        "Checkpoint",
                        "Result"
                    ],
                    "message": "Category is required for the first row of a group"
                }
            ]
        }
      ]
    },
